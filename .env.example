# ============================================
# Portfolio Environment Variables
# ============================================
#
# Copy this file to .env and fill in your values
# Never commit .env to version control!

# --------------------------------------------
# Required: AI Chat Integration
# --------------------------------------------
# Get your Groq API key from: https://console.groq.com/keys
# This enables the interactive terminal chatbot feature
GROQ_API_KEY=your_groq_api_key_here

# --------------------------------------------
# Required for lead capture: Neon Postgres
# --------------------------------------------
# Connection string from the Neon console (https://console.neon.tech).
# Stores contact messages and copilot lead captures (name, email, message).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --------------------------------------------
# OAuth sign-in for the copilot gate (Google + GitHub)
# --------------------------------------------
# Google: create an OAuth Client ID (type: Web application) at
# https://console.cloud.google.com/apis/credentials with these
# Authorized JavaScript origins: https://adityatiwari.work,
# https://www.adityatiwari.work, http://localhost:4321
PUBLIC_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# GitHub: create an OAuth App at https://github.com/settings/developers
# Authorization callback URL: https://adityatiwari.work/api/auth/github/callback
# (add a second app or localhost callback for dev: http://localhost:4321/api/auth/github/callback)
PUBLIC_GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# --------------------------------------------
# Server-side guard secret
# --------------------------------------------
# Used to hash the IP+User-Agent identifiers that drive the copilot's
# server-side rate limiting and auth gate. Set any long random string.
# Falls back to DATABASE_URL if unset, but a dedicated secret is recommended.
APP_SECRET=generate_a_long_random_string

# --------------------------------------------
# Optional: Site Configuration
# --------------------------------------------
# Your production website URL (used for SEO and sitemap generation)
# PUBLIC_SITE_URL=https://yourusername.vercel.app

# --------------------------------------------
# Optional: Analytics (if using Vercel Analytics)
# --------------------------------------------
# These are typically auto-configured by Vercel
# VERCEL_ANALYTICS_ID=your_analytics_id
# VERCEL_ENV=production
