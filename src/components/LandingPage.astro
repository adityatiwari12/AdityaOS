---
import { getImage } from 'astro:assets';
import AppLayout from '../layouts/AppLayout';
import macBackground1 from '../assets/images/mac-background1.jpg';
import macBackground2 from '../assets/images/mac-background2.jpg';
import macBackground3 from '../assets/images/mac-background3.jpg';

const backgrounds = [macBackground1, macBackground2, macBackground3];

const optimizedBackgrounds = await Promise.all(
  backgrounds.map((bg) =>
    getImage({
      src: bg,
      width: 3500,
    })
  )
);

// Apple photo wallpapers (bg-1 = Catalina island = the default Apple wallpaper)
const photoMap = Object.fromEntries(
  optimizedBackgrounds.map((bg, index) => [`bg-${index + 1}`, bg.src])
);

// Real photographic wallpapers (mountains, weather, valleys) served from
// /public/wallpapers. "Shuffle Background" cycles through these crisp images —
// no blur/gradient effect.
const photoWallpapers = {
  'wp-mountains-1': '/wallpapers/mountains-1.jpg',
  'wp-mountains-2': '/wallpapers/mountains-2.jpg',
  'wp-mountains-3': '/wallpapers/mountains-3.jpg',
  'wp-weather-1': '/wallpapers/weather-1.jpg',
  'wp-weather-2': '/wallpapers/weather-2.jpg',
  'wp-valley-1': '/wallpapers/valley-1.jpg',
};

const backgroundMap = { ...photoMap, ...photoWallpapers };
---

<AppLayout
  client:load
  initialBg="bg-1"
  backgroundMap={backgroundMap}
/>
